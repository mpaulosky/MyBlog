<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="css/tailwind.css" />
    <link rel="stylesheet" href="@Assets["MyBlog.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script>
      (function () {
        var themes = ["theme-red", "theme-blue", "theme-green", "theme-yellow"];

        function applyTheme() {
          if (localStorage.getItem("darkMode") === "true") {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
          themes.forEach(function (c) { document.body.classList.remove(c); });
          document.body.classList.add(localStorage.getItem("colorTheme") || "theme-blue");
        }

        applyTheme();

        // Re-apply after Blazor enhanced navigation (both known event names)
        document.addEventListener("enhancedload", applyTheme);
        document.addEventListener("blazor:navigated", applyTheme);

        // Defensive: MutationObserver catches any remaining cases where Blazor
        // strips the classes we added (e.g. timing edge cases in DOM patching)
        var observer = new MutationObserver(function () {
          var needsDark = localStorage.getItem("darkMode") === "true";
          if (needsDark !== document.documentElement.classList.contains("dark")) {
            needsDark
              ? document.documentElement.classList.add("dark")
              : document.documentElement.classList.remove("dark");
          }
          var savedTheme = localStorage.getItem("colorTheme") || "theme-blue";
          if (!document.body.classList.contains(savedTheme)) {
            themes.forEach(function (c) { document.body.classList.remove(c); });
            document.body.classList.add(savedTheme);
          }
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
        observer.observe(document.body, { attributes: true, attributeFilter: ["class"] });

        // Update localStorage BEFORE modifying the class so the observer
        // always reads consistent state and doesn't fight the toggle
        window.setTheme = function (t) {
          localStorage.setItem("colorTheme", t);
          themes.forEach(function (c) { document.body.classList.remove(c); });
          document.body.classList.add(t);
        };

        window.toggleDark = function () {
          var isDark = !document.documentElement.classList.contains("dark");
          localStorage.setItem("darkMode", String(isDark));
          isDark
            ? document.documentElement.classList.add("dark")
            : document.documentElement.classList.remove("dark");
          return isDark;
        };
      })();
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
