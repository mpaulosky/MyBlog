<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="css/tailwind.css" />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link rel="stylesheet" href="@Assets["MyBlog.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script>
      (function () {
        // Restore dark mode
        if (localStorage.getItem("darkMode") === "true") {
          document.documentElement.classList.add("dark");
        }
        // Restore colour theme (default: blue)
        var theme = localStorage.getItem("colorTheme") || "theme-blue";
        document.body.classList.add(theme);

        // Called from Blazor via IJSRuntime.InvokeVoidAsync("setTheme", "theme-red")
        window.setTheme = function (t) {
          ["theme-red", "theme-blue", "theme-green", "theme-yellow"].forEach(function (c) {
            document.body.classList.remove(c);
          });
          document.body.classList.add(t);
          localStorage.setItem("colorTheme", t);
        };

        // Called from Blazor via IJSRuntime.InvokeVoidAsync("toggleDark")
        window.toggleDark = function () {
          var isDark = document.documentElement.classList.toggle("dark");
          localStorage.setItem("darkMode", String(isDark));
        };
      })();
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
