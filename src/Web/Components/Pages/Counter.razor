@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1 class="text-3xl font-bold mb-6">Counter</h1>

<p role="status" class="mb-4 text-content">Current count: @currentCount</p>

<button class="px-4 py-2 rounded font-medium text-white bg-primary hover:bg-primary-hover transition" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
