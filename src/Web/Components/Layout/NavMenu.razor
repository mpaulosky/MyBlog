@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@rendermode InteractiveServer

<nav class="fixed top-0 left-0 right-0 z-50 bg-surface border-b border-edge shadow-sm"
     aria-label="Main navigation">
    <div class="mx-auto max-w-7xl px-4">
        <div class="flex items-center justify-between h-16">

            @* Brand *@
            <NavLink class="text-primary text-xl font-bold hover:opacity-80 transition-opacity"
                     href="" Match="NavLinkMatch.All">
                MyBlog
            </NavLink>

            @* Mobile hamburger (pure CSS peer toggle — no JS required) *@
            <input type="checkbox" id="menu-toggle" class="peer sr-only" aria-hidden="true" />
            <label for="menu-toggle"
                   class="md:hidden cursor-pointer p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-700"
                   aria-label="Toggle navigation">
                @* Heroicon: bars-3 *@
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </label>

            @* Desktop nav links *@
            <div class="hidden md:flex items-center gap-5">
                <NavLink class="nav-link hover:opacity-75 transition-opacity" href="" Match="NavLinkMatch.All">
                    Home
                </NavLink>

                <NavLink class="nav-link hover:opacity-75 transition-opacity" href="blog">
                    Blog Posts
                </NavLink>

                <AuthorizeView Roles="Author,Admin">
                    <Authorized>
                        <NavLink class="nav-link hover:opacity-75 transition-opacity" href="blog/create">
                            New Post
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <NavLink class="nav-link hover:opacity-75 transition-opacity" href="admin/users">
                            Manage Users
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                @* Theme colour switcher *@
                <div class="flex items-center gap-1" aria-label="Colour theme">
                    <button @onclick='() => JS.InvokeVoidAsync("setTheme", "theme-red")'
                            class="w-5 h-5 rounded-full bg-red-600 hover:ring-2 ring-red-400 transition"
                            aria-label="Red theme" title="Red theme"></button>
                    <button @onclick='() => JS.InvokeVoidAsync("setTheme", "theme-blue")'
                            class="w-5 h-5 rounded-full bg-blue-600 hover:ring-2 ring-blue-400 transition"
                            aria-label="Blue theme" title="Blue theme"></button>
                    <button @onclick='() => JS.InvokeVoidAsync("setTheme", "theme-green")'
                            class="w-5 h-5 rounded-full bg-green-600 hover:ring-2 ring-green-400 transition"
                            aria-label="Green theme" title="Green theme"></button>
                    <button @onclick='() => JS.InvokeVoidAsync("setTheme", "theme-yellow")'
                            class="w-5 h-5 rounded-full bg-yellow-500 hover:ring-2 ring-yellow-300 transition"
                            aria-label="Yellow theme" title="Yellow theme"></button>
                </div>

                @* Dark mode toggle *@
                <button @onclick="ToggleDark"
                        class="p-1.5 rounded hover:bg-gray-100 dark:hover:bg-gray-700 transition"
                        aria-label="Toggle dark mode" title="Toggle dark mode">
                    🌙
                </button>

                @* Login / Logout *@
                <AuthorizeView>
                    <Authorized>
                        <a class="nav-link hover:opacity-75 transition-opacity" href="/Account/Logout">
                            Logout (@context.User.Identity?.Name)
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="nav-link hover:opacity-75 transition-opacity" href="/Account/Login">
                            Login
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        @* Mobile nav (shown when peer checkbox is checked) *@
        <div class="hidden peer-checked:flex flex-col pb-4 md:hidden gap-1"
             id="mobile-menu">
            <NavLink class="nav-link hover:opacity-75 py-2 block" href="" Match="NavLinkMatch.All">
                Home
            </NavLink>

            <NavLink class="nav-link hover:opacity-75 py-2 block" href="blog">
                Blog Posts
            </NavLink>

            <AuthorizeView Roles="Author,Admin">
                <Authorized>
                    <NavLink class="nav-link hover:opacity-75 py-2 block" href="blog/create">
                        New Post
                    </NavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink class="nav-link hover:opacity-75 py-2 block" href="admin/users">
                        Manage Users
                    </NavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <a class="nav-link hover:opacity-75 py-2 block" href="/Account/Logout">
                        Logout (@context.User.Identity?.Name)
                    </a>
                </Authorized>
                <NotAuthorized>
                    <a class="nav-link hover:opacity-75 py-2 block" href="/Account/Login">
                        Login
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

@code {
    private async Task ToggleDark() =>
        await JS.InvokeVoidAsync("toggleDark");
}
