@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@rendermode InteractiveServer

<nav class="fixed top-0 left-0 right-0 z-50 bg-surface border-b border-edge shadow-sm"
     aria-label="Main navigation">
    <div class="mx-auto max-w-7xl px-4">
        <div class="flex items-center justify-between h-16">

            @* Brand *@
            <NavLink class="text-primary text-xl font-bold hover:opacity-80 transition-opacity"
                     href="" Match="NavLinkMatch.All">
                MyBlog
            </NavLink>

            @* Mobile hamburger (pure CSS peer toggle — no JS required) *@
            <input type="checkbox" id="menu-toggle" class="peer sr-only" aria-hidden="true" />
            <label for="menu-toggle"
                   class="md:hidden cursor-pointer p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-700"
                   aria-label="Toggle navigation">
                @* Heroicon: bars-3 *@
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </label>

            @* Desktop nav links *@
            <div class="hidden md:flex items-center gap-5">
                <NavLink class="nav-link hover:opacity-75 transition-opacity" href="" Match="NavLinkMatch.All">
                    Home
                </NavLink>

                <NavLink class="nav-link hover:opacity-75 transition-opacity" href="blog">
                    Blog Posts
                </NavLink>

                <AuthorizeView Roles="Author,Admin">
                    <Authorized>
                        <NavLink class="nav-link hover:opacity-75 transition-opacity" href="blog/create">
                            New Post
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <NavLink class="nav-link hover:opacity-75 transition-opacity" href="admin/users">
                            Manage Users
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                @* Theme colour switcher *@
                <select @onchange="OnThemeChanged"
                        class="text-sm rounded border border-edge bg-surface text-content px-2 py-1 cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary"
                        aria-label="Colour theme" title="Select colour theme">
                    <option value="theme-red"    selected="@(_currentTheme == "theme-red")">🔴 Red</option>
                    <option value="theme-blue"   selected="@(_currentTheme == "theme-blue")">🔵 Blue</option>
                    <option value="theme-green"  selected="@(_currentTheme == "theme-green")">🟢 Green</option>
                    <option value="theme-yellow" selected="@(_currentTheme == "theme-yellow")">🟡 Yellow</option>
                </select>

                @* Dark mode toggle *@
                <button @onclick="ToggleDark"
                        class="p-1.5 rounded hover:bg-gray-100 dark:hover:bg-gray-700 transition"
                        aria-label="Toggle dark mode" title="Toggle dark mode">
                    @(_isDark ? "☀️" : "🌙")
                </button>

                @* Login / Logout *@
                <AuthorizeView>
                    <Authorized>
                        <a class="nav-link hover:opacity-75 transition-opacity" href="/Account/Logout">
                            Logout (@context.User.Identity?.Name)
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="nav-link hover:opacity-75 transition-opacity" href="/Account/Login">
                            Login
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        @* Mobile nav (shown when peer checkbox is checked) *@
        <div class="hidden peer-checked:flex flex-col pb-4 md:hidden gap-1"
             id="mobile-menu">
            <NavLink class="nav-link hover:opacity-75 py-2 block" href="" Match="NavLinkMatch.All">
                Home
            </NavLink>

            <NavLink class="nav-link hover:opacity-75 py-2 block" href="blog">
                Blog Posts
            </NavLink>

            <AuthorizeView Roles="Author,Admin">
                <Authorized>
                    <NavLink class="nav-link hover:opacity-75 py-2 block" href="blog/create">
                        New Post
                    </NavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink class="nav-link hover:opacity-75 py-2 block" href="admin/users">
                        Manage Users
                    </NavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <a class="nav-link hover:opacity-75 py-2 block" href="/Account/Logout">
                        Logout (@context.User.Identity?.Name)
                    </a>
                </Authorized>
                <NotAuthorized>
                    <a class="nav-link hover:opacity-75 py-2 block" href="/Account/Login">
                        Login
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

@code {
    private bool _isDark = false;
    private string _currentTheme = "theme-blue";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDark = await JS.InvokeAsync<bool>("eval", "document.documentElement.classList.contains('dark')");
            var stored = await JS.InvokeAsync<string?>("eval", "localStorage.getItem('colorTheme')");
            _currentTheme = string.IsNullOrEmpty(stored) ? "theme-blue" : stored;
            StateHasChanged();
        }
    }

    private async Task OnThemeChanged(ChangeEventArgs e)
    {
        _currentTheme = e.Value?.ToString() ?? "theme-blue";
        await JS.InvokeVoidAsync("setTheme", _currentTheme);
    }

    private async Task ToggleDark()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("toggleDark");
    }
}
