@inherits LayoutComponentBase

<div class="min-h-screen bg-canvas text-content">
    <NavMenu />

    <main class="mx-auto max-w-7xl px-4 pt-20 pb-8">
        @Body
    </main>

    <footer class="border-t border-primary-700 bg-primary-800 text-primary-50 py-4 text-center text-sm">
        <p>&copy; @DateTime.Now.Year MyBlog — Training Project</p>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
