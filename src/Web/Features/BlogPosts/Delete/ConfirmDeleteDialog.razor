@using Microsoft.AspNetCore.Components

@if (_isVisible)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/50" @onclick="OnCancel">
        <div class="rounded-lg shadow-xl p-6 max-w-md w-full mx-4 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600" @onclick:stopPropagation="true" role="dialog" aria-labelledby="dialog-title">
            <h5 id="dialog-title" class="text-lg font-semibold text-gray-900 dark:text-gray-50 mb-4">Confirm Delete</h5>
            <div class="mb-4">
                <p class="text-gray-900 dark:text-gray-50 mb-2">Are you sure you want to delete <strong>@PostTitle</strong>?</p>
                <p class="text-red-600 dark:text-red-400 text-sm">This action cannot be undone.</p>
            </div>
            <div class="flex gap-2 justify-end">
                <button class="px-4 py-2 rounded font-medium bg-red-600 text-white hover:bg-red-700 transition" @onclick="OnConfirm">Delete</button>
                <button class="px-4 py-2 rounded font-medium border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-gray-50 hover:bg-gray-100 dark:hover:bg-gray-700 transition" @onclick="OnCancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string PostTitle { get; set; } = string.Empty;
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool _isVisible => IsVisible;
}
