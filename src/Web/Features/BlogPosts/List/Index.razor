@page "/blog"
@using MediatR
@using MyBlog.Web.Data
@using MyBlog.Web.Features.BlogPosts.Delete
@using MyBlog.Web.Features.BlogPosts.List
@using Microsoft.AspNetCore.Components.Authorization
@inject ISender Sender
@rendermode InteractiveServer
@attribute [StreamRendering]

<PageTitle>Blog Posts</PageTitle>

<h1 class="text-3xl font-bold mb-6">Blog Posts</h1>

@if (_error is not null)
{
    <div class="rounded-lg border border-red-300 bg-red-50 text-red-700 px-4 py-3 text-sm mb-4 flex items-center justify-between" role="alert">
        <span>@_error</span>
        <button type="button" class="ml-4 cursor-pointer text-red-700 hover:text-red-900" @onclick="() => _error = null">&times;</button>
    </div>
}

@if (_concurrencyError)
{
    <div class="rounded-lg border border-yellow-300 bg-yellow-50 text-yellow-700 px-4 py-3 text-sm mb-4 flex items-center justify-between" role="alert">
        <div>
            <strong class="font-semibold">Concurrency Conflict:</strong> This post was modified by another user. 
            Please reload the page to get the latest version.
        </div>
        <button type="button" class="ml-4 cursor-pointer text-yellow-700 hover:text-yellow-900" @onclick="() => _concurrencyError = false">&times;</button>
    </div>
}

<AuthorizeView Roles="Author,Admin">
    <Authorized>
        <a href="/blog/create" class="inline-block px-4 py-2 rounded font-medium text-white bg-primary hover:bg-primary-hover transition mb-4">New Post</a>
    </Authorized>
</AuthorizeView>

@if (_posts is null)
{
    <p class="text-muted">Loading...</p>
}
else if (!_posts.Any())
{
    <p class="text-muted">No posts yet.</p>
}
else
{
    <div class="rounded-lg shadow bg-surface overflow-hidden">
        <table class="w-full text-sm text-left text-content">
            <thead class="bg-canvas text-muted border-b border-edge">
                <tr>
                    <th class="px-4 py-3">Title</th>
                    <th class="px-4 py-3">Author</th>
                    <th class="px-4 py-3">Published</th>
                    <th class="px-4 py-3">Created</th>
                    <AuthorizeView Roles="Author,Admin">
                        <Authorized>
                            <th class="px-4 py-3"></th>
                        </Authorized>
                    </AuthorizeView>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in _posts)
                {
                    <tr class="odd:bg-canvas even:bg-surface border-b border-edge hover:bg-gray-100 dark:hover:bg-gray-700 transition">
                        <td class="px-4 py-3">@post.Title</td>
                        <td class="px-4 py-3">@post.Author</td>
                        <td class="px-4 py-3">@(post.IsPublished ? "Yes" : "No")</td>
                        <td class="px-4 py-3">@post.CreatedAt.ToShortDateString()</td>
                        <AuthorizeView Roles="Author,Admin">
                            <Authorized>
                                <td class="px-4 py-3">
                                    <a href="/blog/edit/@post.Id" class="inline-block px-3 py-1 text-sm rounded font-medium border border-edge text-content hover:bg-surface transition mr-1">Edit</a>
                                    <button class="inline-block px-3 py-1 text-sm rounded font-medium bg-red-600 text-white hover:bg-red-700 transition"
                                            @onclick="() => ConfirmDelete(post)">Delete</button>
                                </td>
                            </Authorized>
                        </AuthorizeView>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<ConfirmDeleteDialog
    IsVisible="_showDeleteDialog"
    PostTitle="@(_postToDelete?.Title ?? string.Empty)"
    OnConfirm="ExecuteDelete"
    OnCancel="@(() => _showDeleteDialog = false)" />

@code {
    private IReadOnlyList<BlogPostDto>? _posts;
    private BlogPostDto? _postToDelete;
    private bool _showDeleteDialog;
    private string? _error;
    private bool _concurrencyError;

    protected override async Task OnInitializedAsync()
    {
        var result = await Sender.Send(new GetBlogPostsQuery());
        if (result.Success)
            _posts = result.Value;
        else
            _error = result.Error;
    }

    private void ConfirmDelete(BlogPostDto post)
    {
        _postToDelete = post;
        _showDeleteDialog = true;
    }

    private async Task ExecuteDelete()
    {
        if (_postToDelete is not null)
        {
            var result = await Sender.Send(new DeleteBlogPostCommand(_postToDelete.Id));
            if (result.Failure)
            {
                _error = result.Error;
                if (result.ErrorCode == global::Domain.Abstractions.ResultErrorCode.Concurrency)
                    _concurrencyError = true;
                _showDeleteDialog = false;
                _postToDelete = null;
                return;
            }
        }
        _showDeleteDialog = false;
        _postToDelete = null;
        var listResult = await Sender.Send(new GetBlogPostsQuery());
        if (listResult.Success)
            _posts = listResult.Value;
        else
            _error = listResult.Error;
    }
}
