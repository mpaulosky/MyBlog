@page "/blog"
@using MyBlog.Web.Features.BlogPosts.Delete
@inject ISender Sender
@rendermode InteractiveServer
@attribute [StreamRendering]

<PageHeadingComponent HeaderText="Blog Posts" Level="1" TextColorClass="text-primary-900 dark:text-primary-50" />

@if (_error is not null)
{
	<div class="alert-error" role="alert">
		<span>@_error</span>
		<button type="button" class="alert-dismiss" @onclick="() => _error = null">&times;</button>
	</div>
}

@if (_concurrencyError)
{
	<div class="alert-warning" role="alert">
		<div>
			<strong class="font-semibold">Concurrency Conflict:</strong> This post was modified by another user.
			Please reload the page to get the latest version.
		</div>
		<button type="button" class="alert-dismiss" @onclick="() => _concurrencyError = false">&times;</button>
	</div>
}

<AuthorizeView Roles="Author,Admin">
	<Authorized>
		<a href="/blog/create" class="btn-primary inline-block mb-4">New Post</a>
	</Authorized>
</AuthorizeView>

@if (_posts is null)
{
	<p>Loading...</p>
}
else if (!_posts.Any())
{
	<p>No posts yet.</p>
}
else
{
	<div class="table-wrapper">
		<table class="data-table">
			<thead>
				<tr>
					<th>Title</th>
					<th>Author</th>
					<th>Published</th>
					<th>Created</th>
					<AuthorizeView Roles="Author,Admin">
						<Authorized>
							<th></th>
						</Authorized>
					</AuthorizeView>
				</tr>
			</thead>
			<tbody>
				@foreach (var post in _posts)
				{
					<tr>
						<td>@post.Title</td>
						<td>@post.AuthorName</td>
						<td>@(post.IsPublished ? "Yes" : "No")</td>
						<td>@post.CreatedAt.ToShortDateString()</td>
						<AuthorizeView Roles="Author,Admin">
							<Authorized>
								<td>
									<a href="/blog/edit/@post.Id" class="btn-secondary inline-block mr-1">Edit</a>
									<button class="btn-destructive" @onclick="() => ConfirmDelete(post)">Delete</button>
								</td>
							</Authorized>
						</AuthorizeView>
					</tr>
				}
			</tbody>
		</table>
	</div>
}

<ConfirmDeleteDialog IsVisible="_showDeleteDialog" PostTitle="@(_postToDelete?.Title ?? string.Empty)"
										 OnConfirm="ExecuteDelete" OnCancel="@(() => _showDeleteDialog = false)" />

@code {
	private IReadOnlyList<BlogPostDto>? _posts;
	private BlogPostDto? _postToDelete;
	private bool _showDeleteDialog;
	private string? _error;
	private bool _concurrencyError;

	protected override async Task OnInitializedAsync()
	{
		var result = await Sender.Send(new GetBlogPostsQuery());
		if (result.Success)
			_posts = result.Value;
		else
			_error = result.Error;
	}

	private void ConfirmDelete(BlogPostDto post)
	{
		_postToDelete = post;
		_showDeleteDialog = true;
	}

	private async Task ExecuteDelete()
	{
		if (_postToDelete is not null)
		{
			var result = await Sender.Send(new DeleteBlogPostCommand(ObjectId.Parse(_postToDelete.Id)));
			if (result.Failure)
			{
				_error = result.Error;
				if (result.ErrorCode == global::MyBlog.Domain.Abstractions.ResultErrorCode.Concurrency)
					_concurrencyError = true;
				_showDeleteDialog = false;
				_postToDelete = null;
				return;
			}
		}
		_showDeleteDialog = false;
		_postToDelete = null;
		var listResult = await Sender.Send(new GetBlogPostsQuery());
		if (listResult.Success)
			_posts = listResult.Value;
		else
			_error = listResult.Error;
	}
}
