  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.0",
    "markdownlint-cli2": "^0.23.0",
    "tailwindcss": "^4.2.0"
  },
  "allowScripts": {
    "@parcel/watcher": true
  }
}
