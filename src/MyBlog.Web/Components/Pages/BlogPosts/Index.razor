@page "/blog"
@using MyBlog.Domain.Entities
@using MyBlog.Domain.Interfaces
@inject IBlogPostRepository Repository
@rendermode InteractiveServer

<PageTitle>Blog Posts</PageTitle>

<h1>Blog Posts</h1>

<a href="/blog/create" class="btn btn-primary mb-3">New Post</a>

@if (_posts is null)
{
    <p>Loading...</p>
}
else if (!_posts.Any())
{
    <p>No posts yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Published</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in _posts)
            {
                <tr>
                    <td>@post.Title</td>
                    <td>@post.Author</td>
                    <td>@(post.IsPublished ? "Yes" : "No")</td>
                    <td>@post.CreatedAt.ToShortDateString()</td>
                    <td>
                        <a href="/blog/edit/@post.Id" class="btn btn-sm btn-secondary">Edit</a>
                        <button class="btn btn-sm btn-danger"
                                @onclick="() => ConfirmDelete(post)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<ConfirmDeleteDialog
    IsVisible="_showDeleteDialog"
    PostTitle="@(_postToDelete?.Title ?? string.Empty)"
    OnConfirm="ExecuteDelete"
    OnCancel="@(() => _showDeleteDialog = false)" />

@code {
    private IReadOnlyList<BlogPost>? _posts;
    private BlogPost? _postToDelete;
    private bool _showDeleteDialog;

    protected override async Task OnInitializedAsync()
        => _posts = await Repository.GetAllAsync();

    private void ConfirmDelete(BlogPost post)
    {
        _postToDelete = post;
        _showDeleteDialog = true;
    }

    private async Task ExecuteDelete()
    {
        if (_postToDelete is not null)
            await Repository.DeleteAsync(_postToDelete.Id);
        _showDeleteDialog = false;
        _postToDelete = null;
        _posts = await Repository.GetAllAsync();
    }
}
